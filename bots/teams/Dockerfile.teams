FROM python:3.11-slim

WORKDIR /app

COPY . /app

RUN apt-get update && apt-get install -y build-essential gcc \
    && python -m pip install --upgrade pip

# Install required Python packages; adjust if your api/requirements.txt contains extra libs
RUN pip install -r api/requirements.txt
RUN pip install aiohttp botbuilder-core botbuilder-schema botbuilder-dialogs requests

ENV PYTHONUNBUFFERED=1

EXPOSE 3978

CMD ["python", "bots/teams/app.py"]
